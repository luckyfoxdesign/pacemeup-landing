---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Footer from '../components/Footer.astro';
import { BOT_INVITE_URL, PLANS } from '../config';

const proofSignals = [
  {
    label: 'limiter radar',
    title: 'Know what is holding the day back.',
    text: 'Threshold, speed, economy, durability and recovery are scored as signals, not as dashboard noise.',
    metric: 'recovery limiter',
    tone: 'strain',
  },
  {
    label: 'goal gap',
    title: 'Train the gap, not the fantasy.',
    text: 'The model compares today against the current goal and chooses the next useful session.',
    metric: '10k gap · 3:20',
    tone: 'sync',
  },
  {
    label: 'calendar pressure',
    title: 'Your calendar is part of your physiology.',
    text: 'A 30-minute opening and a 90-minute opening should not produce the same workout.',
    metric: '45 min open',
    tone: 'sync',
  },
  {
    label: 'recovery signal',
    title: 'Bad sleep is training data.',
    text: 'Sleep, HRV trend and recent load can lower the dose before the athlete pays for it.',
    metric: 'dose cut 38%',
    tone: 'volt',
  },
];

const lifeEvents = [
  ['05:42', 'Sleep crashed', 'easy 35 min'],
  ['09:10', 'Work block moved', 'swap to lunch'],
  ['18:30', 'Missed threshold', 'rebuild week'],
  ['07:20', 'HRV steady', 'tempo stays on'],
];

const coachModes = [
  { label: 'character', active: 'Partner', options: ['Analyst', 'Hardline', 'Partner', 'Quiet'] },
  { label: 'communication', active: 'Voice', options: ['Voice', 'Text', 'Mixed'] },
  { label: 'initiative', active: 'Proactive', options: ['Proactive', 'Reactive'] },
];
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Marquee />

    <section id="enemy" class="impact-section border-t border-text bg-text text-paper">
      <div class="section grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
        <div>
          <p class="section-kicker text-base/55">01 / the enemy</p>
          <h2 class="section-title mt-5 max-w-4xl">
            Static plans break the moment life happens.
          </h2>
        </div>
        <div class="enemy-board">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-base/45">yesterday</p>
          <div class="mt-4 grid gap-2 font-mono text-sm">
            <div class="enemy-row"><span>sleep</span><strong>5h 42m</strong></div>
            <div class="enemy-row"><span>stress</span><strong>high</strong></div>
            <div class="enemy-row"><span>meeting block</span><strong>moved</strong></div>
            <div class="enemy-row strike"><span>plan says</span><strong>threshold 8x3</strong></div>
          </div>
          <p class="mt-6 max-w-sm text-lg text-base/72">
            A fixed plan trains the version of you that never slept badly, never missed a run and never had a day job.
          </p>
        </div>
      </div>
    </section>

    <section id="engine" class="page-band">
      <div class="section">
        <div class="section-heading">
          <p class="section-kicker">02 / the engine</p>
          <h2 class="section-title">Inputs feed the athlete model. The model makes today’s decision.</h2>
        </div>

        <div class="engine-flow" aria-label="Pace me up decision engine flow">
          <div class="engine-node">
            <span>signals</span>
            <strong>Coros · sleep · HRV · calendar · check-in</strong>
          </div>
          <div class="engine-arrow" aria-hidden="true"></div>
          <div class="engine-core">
            <p>athlete model</p>
            <svg viewBox="0 0 260 180" role="img" aria-label="adaptive athlete model radar">
              <polygon points="130,18 232,78 202,160 58,160 28,78" fill="none" stroke="#E4DFD3" stroke-width="2" />
              <polygon points="130,46 190,84 178,133 72,145 57,88" fill="#C7FF2E" stroke="#0B0D0C" stroke-width="3" />
              <line x1="130" y1="18" x2="130" y2="160" stroke="#E4DFD3" />
              <line x1="28" y1="78" x2="202" y2="160" stroke="#E4DFD3" />
              <line x1="232" y1="78" x2="58" y2="160" stroke="#E4DFD3" />
            </svg>
          </div>
          <div class="engine-arrow" aria-hidden="true"></div>
          <div class="engine-node decision-node">
            <span>decision</span>
            <strong>easy 35 min</strong>
            <em>because recovery is the limiter today</em>
          </div>
        </div>
      </div>
    </section>

    <section id="proof" class="page-band proof-band">
      <div class="section">
        <div class="section-heading split">
          <div>
            <p class="section-kicker">03 / proof</p>
            <h2 class="section-title">The cockpit shows the reason, not just the workout.</h2>
          </div>
          <p class="section-lead">
            Every signal has a job: explain why the plan changed, what it protects, and what gap it trains next.
          </p>
        </div>

        <div class="proof-grid">
          {proofSignals.map((item) => (
            <article class={`proof-card tone-${item.tone}`}>
              <div class="proof-card-top">
                <span>{item.label}</span>
                <strong>{item.metric}</strong>
              </div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <div class="proof-meter" aria-hidden="true"><span></span></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="coach" class="page-band coach-band">
      <div class="section grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="section-kicker">04 / coach mode</p>
          <h2 class="section-title">Choose the coach you can actually live with.</h2>
          <p class="section-lead mt-6">
            This is not an avatar builder. It controls how training intelligence enters your day: direct, quiet, voice-first or ready to push back.
          </p>
        </div>

        <div class="coach-console">
          {coachModes.map((row) => (
            <div class="coach-row">
              <p>{row.label}</p>
              <div>
                {row.options.map((option) => (
                  <button
                    class:list={[option === row.active ? 'active' : '']}
                    type="button"
                    data-coach-group={row.label}
                    data-coach-option={option}
                  >
                    {option}
                  </button>
                ))}
              </div>
            </div>
          ))}
          <div class="coach-output">
            <span>selected behavior</span>
            <strong id="coach-summary">Proactive Partner / voice when it is easier to talk / quiet when there is nothing to fix.</strong>
          </div>
        </div>
      </div>
    </section>

    <section id="life" class="impact-section bg-text text-paper">
      <div class="section">
        <div class="section-heading split">
          <div>
            <p class="section-kicker text-base/55">05 / life happens</p>
            <h2 class="section-title">Missed sessions should update the plan, not break it.</h2>
          </div>
          <p class="section-lead text-base/70">
            Pace me up treats schedule chaos as input. The system keeps the training thread alive when the original plan stops matching reality.
          </p>
        </div>

        <div class="life-timeline">
          {lifeEvents.map(([time, event, decision]) => (
            <div class="life-event">
              <span>{time}</span>
              <strong>{event}</strong>
              <em>{decision}</em>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="narrative" class="page-band narrative-band">
      <div class="section grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div>
          <p class="section-kicker">06 / narrative</p>
          <h2 class="section-title">The next workout comes with a reason.</h2>
          <p class="section-lead mt-6">
            Product text stays human. No acronym soup, no raw physiology lecture, no motivational fog.
          </p>
        </div>
        <div class="message-stack">
          <div class="message system">
            <span>today</span>
            <p>Easy 35 minutes. Keep it light.</p>
          </div>
          <div class="message coach">
            <span>why</span>
            <p>You slept poorly and yesterday was already hard. Today is for absorbing the work, not proving a point.</p>
          </div>
          <div class="message athlete">
            <span>athlete</span>
            <p>Can I still do tempo?</p>
          </div>
          <div class="message coach">
            <span>coach</span>
            <p>Not today. Move tempo to the next open slot and keep the streak useful.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing" class="page-band pricing-band">
      <div class="section">
        <div class="section-heading split">
          <div>
            <p class="section-kicker">07 / pricing</p>
            <h2 class="section-title">Start free. Go Pro when you want the full cockpit.</h2>
          </div>
          <p class="section-lead">
            Access is invite-only while the MVP is being tuned. Pricing and limits are draft, but the product shape is clear.
          </p>
        </div>

        <div class="pricing-grid">
          {PLANS.map((plan) => (
            <article class:list={['price-card', plan.highlight && 'featured']}>
              <div class="price-head">
                <p>{plan.name}</p>
                <span>{plan.note}</span>
              </div>
              <div class="price">
                <strong>{plan.price}</strong>{plan.period && <em>{plan.period}</em>}
              </div>
              <ul>
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
              <a href={BOT_INVITE_URL} class:list={[plan.highlight ? 'btn-volt' : 'btn-primary']} rel="noopener" target="_blank">
                {plan.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="final-cta">
      <div class="section">
        <p class="section-kicker">beta access</p>
        <h2>Pace me up trains the actual one.</h2>
        <a href={BOT_INVITE_URL} class="btn-primary" rel="noopener" target="_blank">Request an invite</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const selectedCoach: Record<string, string> = {
    character: 'Partner',
    communication: 'Voice',
    initiative: 'Proactive',
  };

  const coachCopy: Record<string, string> = {
    Analyst: 'explains the model before the move',
    Hardline: 'pushes when the data says go',
    Partner: 'keeps the day usable',
    Quiet: 'stays out until there is a reason',
    Voice: 'voice when it is easier to talk',
    Text: 'text when you want control',
    Mixed: 'voice or text by context',
    Proactive: 'moves first when the plan needs to change',
    Reactive: 'waits for sync, check-in or a direct question',
  };

  const summary = document.getElementById('coach-summary');
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-coach-group]');

  function renderCoachSummary() {
    if (!summary) return;
    summary.textContent = `${selectedCoach.initiative} ${selectedCoach.character} / ${coachCopy[selectedCoach.communication]} / ${coachCopy[selectedCoach.initiative]}.`;
  }

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const group = button.dataset.coachGroup;
      const option = button.dataset.coachOption;
      if (!group || !option) return;

      selectedCoach[group] = option;
      document
        .querySelectorAll<HTMLButtonElement>(`[data-coach-group="${group}"]`)
        .forEach((item) => item.classList.toggle('active', item === button));
      renderCoachSummary();
    });
  });
</script>
